# JWT — firma de tokens (genera valores únicos en producción)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# JWT — expiración del token (formato: 15m, 1h, 7d)
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Segundos que devuelve la API en expiresIn (1h = 3600)
JWT_EXPIRES_IN=3600

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# PostgreSQL (docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=notcloud
DB_SYNCHRONIZE=true

# API
PORT=3000

# CORS (* = cualquier origen)
CORS_ENABLED=true
CORS_ORIGIN=*
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=api

# RFC 7807 Problem Details
PROBLEM_DETAILS_BASE_URL=https://notcloud.local/problems
